# ─────────────────────────────────────────────────────────────────
# ISMS Compass — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# Flask
FLASK_DEBUG=0
PORT=5000

# JWT — change this to a long random string in production
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=isms-compass-change-this-secret-in-production

# Database
# SQLite (default — no setup needed):
# DATABASE_URL is left unset → uses isms_compass.db in the backend folder
#
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/isms_compass

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── AI Engine ─────────────────────────────────────────────────────
# Gemini (cloud AI — primary engine)
# Get your key from https://aistudio.google.com
# NOTE: No VITE_ prefix — this key must NEVER reach the browser bundle
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Ollama (local AI — fallback engine)
# Install Ollama from https://ollama.com, then: ollama pull qwen2.5:7b
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
# Ollama defaults to a low token cap without this — long SoA drafts get cut off after a heading
OLLAMA_NUM_PREDICT=2048
OLLAMA_TEMPERATURE=0.7

# ── Seed demo data on startup ──────────────────────────────────────
# Set to 1 to auto-seed SafeRoute Logistics demo data on first run
# Or run: python app.py --seed
SEED_DB=0

# ── Email (SMTP) ────────────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_NAME=ISMS Compass
MAIL_FROM_ADDRESS=your-email@gmail.com
FRONTEND_URL=http://localhost:5173
